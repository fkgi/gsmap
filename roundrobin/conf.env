## configuration of Round-Robin debugger for MAP

## SIGTRAN protocol parameter
# local address: IP[:port] (default port: 2905)
LOCAL_ADDR=192.168.99.11:2905

# local point code: digits
LOCAL_POINT_CODE=123

# routing context: digits
ROUTING_CONTEXT=1

# network indicator: international|spare|national|reserved (default: international)
NETWORK_INDICATOR=international

# network appearance: digits (default: )
NETWORK_APPEARANCE=

# global title digits: digits
GLOBAL_TITLE=123456789

# subsystem number: msc|hlr|vlr (default: msc)
SUBSYSTEM_NUMBER=msc

# peer STP address: IP[:port] (default port: 2905)
# peer point code: digits
PEER_ADDR0=192.168.99.12
ADJACENT_POINT_CODE0=987
PEER_ADDR1=192.168.99.13:2905
ADJACENT_POINT_CODE1=987
PEER_ADDR2=
ADJACENT_POINT_CODE2=
PEER_ADDR3=
ADJACENT_POINT_CODE3=
PEER_ADDR4=
ADJACENT_POINT_CODE4=
PEER_ADDR5=
ADJACENT_POINT_CODE5=
PEER_ADDR6=
ADJACENT_POINT_CODE6=
PEER_ADDR7=
ADJACENT_POINT_CODE7=
PEER_ADDR8=
ADJACENT_POINT_CODE8=
PEER_ADDR9=
ADJACENT_POINT_CODE9=

# MAP request timeout time of second (default: 30)
TIMEOUT=30

## API parameter
# local API listening address
LOCALAPI_ADDR=localhost:8080

# backend API peer address
BACKENDAPI_ADDR=localhost:8080

# verbose log output: yes|no (default: no)
VERBOSE=yes
